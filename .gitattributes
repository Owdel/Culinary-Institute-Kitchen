private static void updateStudentLevel() {
    System.out.println("  --- Update Student Level ---");
    Student s = pickStudent();
    if (s == null) return;

    System.out.println("  Current Level: " + s.getLevel());
    System.out.println("  1) Beginner  2) Intermediate  3) Advanced  4) Professional");
    System.out.print("  New Level: ");
    String[] levels = {"Beginner", "Intermediate", "Advanced", "Professional"};
    int c = parseChoice(sc.nextLine().trim(), 1, 4, 0);
    if (c == 0) { System.out.println("  Invalid choice."); pause(); return; }

    s.setLevel(levels[c - 1]);
    System.out.println("  Level updated to: " + s.getLevel());
    pause();
}